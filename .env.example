# Copy this file to .env and fill in your own values before running deploy.sh.

# Access mode: tailscale or oidc.
ACCESS_MODE=tailscale

# Required when ACCESS_MODE=tailscale: ephemeral or reusable Tailscale auth key used to join the container.
TS_AUTHKEY=tskey-auth-example

# Incus container settings.
CONTAINER_NAME=incus-web
IMAGE=images:debian/trixie
RECREATE=0
INCUS_NETWORK=agentbr0
INCUS_NETWORK_IPV4=198.18.0.1/15
INCUS_ACL=agent-block-lan
ENABLE_NETWORK_ACL=1
INCUS_PROFILE_NAME=incus-web-agent
# Optional local override. When unset, deploy.sh uses ./incus-web-profile.yaml or fetches it for curl-piped runs.
INCUS_PROFILE_YAML=
CONTAINER_IPV4=

# Control-plane imported workspace metadata. The first host-local provisioner
# imports the existing prototype container before generated per-user projects
# are enabled.
INCUS_WEB_WORKSPACE_ID=workspace-incus-web
INCUS_WEB_INCUS_PROJECT=default
INCUS_WEB_INCUS_CONTAINER=

# Host-local provisioner service. deploy.sh installs this as a host systemd
# service and generates a persistent token when INCUS_WEB_PROVISIONER_TOKEN is
# blank. Use the same token/socket env in the Next.js app process.
ENABLE_HOST_PROVISIONER=1
INCUS_WEB_PROVISIONER_TOKEN=
INCUS_WEB_PROVISIONER_SOCKET=/run/incus-web/provisioner.sock
INCUS_WEB_PROVISIONER_SOCKET_MODE=0660
INCUS_WEB_PROVISIONER_USER=incus-web-provisioner
INCUS_WEB_PROVISIONER_GROUP=incus-web
INCUS_WEB_PROVISIONER_INCUS_GROUP=incus-admin
INCUS_WEB_PROVISIONER_NODE=/usr/bin/node
INCUS_WEB_APP_NPM=/usr/bin/npm
ENABLE_HOST_PROVISIONER_REMOTE_DOWNLOAD=0

# Host Next.js control-plane app. This is the primary browser surface when
# SWAG routes incus-web.tootie.tv to the host app port.
ENABLE_HOST_WEB_APP=1
INCUS_WEB_APP_DIR=
INCUS_WEB_APP_ENV_FILE=/etc/incus-web/web.env
INCUS_WEB_APP_USER=
INCUS_WEB_APP_HOST=127.0.0.1
INCUS_WEB_APP_PORT=3090
INCUS_WEB_WORKSPACE_OWNER_MODE=authenticated
INCUS_WEB_TERMINAL_URL=

# Tailnet identity and HTTPS serving.
TS_HOSTNAME=incus-web
TS_EXTRA_ARGS=--accept-routes=false
TAILSCALE_SERVE_PORT=443

# OIDC reverse proxy settings. Required when ACCESS_MODE=oidc:
# - PUBLIC_URL must be the external URL that reaches oauth2-proxy.
# - Configure your OIDC app callback as: $PUBLIC_URL/oauth2/callback
PUBLIC_URL=https://incus-web.example.com
OIDC_ISSUER_URL=https://issuer.example.com
OIDC_CLIENT_ID=incus-web
OIDC_CLIENT_SECRET=change-me
# Optional. Leave blank to generate a per-container cookie secret during deploy.
OIDC_COOKIE_SECRET=
OIDC_EMAIL_DOMAINS=*
OIDC_ALLOWED_EMAILS=
OIDC_PROVIDER_DISPLAY_NAME=OIDC
OIDC_PROXY_PORT=4180
# Optional Incus proxy device. Leave OIDC_HOST_PORT blank to expose only on the container network.
OIDC_HOST_BIND=127.0.0.1
OIDC_HOST_PORT=
OIDC_COOKIE_SECURE=true
OIDC_REVERSE_PROXY=true
OIDC_SKIP_PROVIDER_BUTTON=true
OIDC_COOKIE_REFRESH=1h
OIDC_COOKIE_EXPIRE=8h
OAUTH2_PROXY_VERSION=v7.15.3

# Web terminal settings.
TERMINAL_BACKEND=wetty
GHOSTTY_WEB_DEMO_VERSION=0.4.0-next.20.g1858a59
SETUP_ENABLED=1
SETUP_PORT=3080
SETUP_ALLOWED_EMAILS=
SETUP_ALLOW_KEY_PERSISTENCE=0
SETUP_COMMAND_TIMEOUT_MS=1200000
IDENTITY_PROXY_PORT=3090
WETTY_PORT=3000
WEB_USER=agent
INCUS_WEB_WORKSPACE_LABEL=

# Optional per-container personal bootstrap. DOTFILES_REPO is passed to
# `chezmoi init --apply` inside this user's workspace container.
# For encrypted chezmoi secrets, point DOTFILES_AGE_KEY_FILE at a local host file
# that can be copied into the container as ~/.config/chezmoi/key.txt.
DOTFILES_REPO=
DOTFILES_SOURCE_DIR=
DOTFILES_AGE_KEY_FILE=
DOTFILES_RUN_MISE=0
# Keep root-level package scripts opt-in; user-level dotfiles and mise still run.
DOTFILES_SKIP_APT=1

# Host path to mount into the container, and where it appears inside the container.
HOST_WORKSPACE=$HOME/incus-web-data/incus-web
CONTAINER_WORKSPACE=/workspace
DISK_SHIFT=true
